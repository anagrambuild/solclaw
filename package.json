{
  "name": "solclaw",
  "version": "0.1.0",
  "description": "Solana AI Agent - Optimized for Solana DeFi protocols",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "setup": "tsx setup/index.ts",
    "setup:all": "./setup-all.sh",
    "setup:solana": "npx tsx setup/index.ts --step solana",
    "reset": "./reset.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.0.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.8.1",
    "bs58": "^6.0.0",
    "chalk": "^5.3.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.39.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
